---
// Decorative QR-like grid for the product mockups. The pattern is computed
// here at BUILD time (the same seeded RNG + finder-pattern logic as the
// design prototype's phone-screens.jsx) and emitted as static <div>s, so the
// rendered page ships zero client JS. It is intentionally NOT a scannable
// code — it stands in for the real app's rotating QR in a marketing shot.
interface Props {
  size?: number;
  color?: string;
}
const { size = 188, color = '#0B0D10' } = Astro.props;

const N = 25;
let s = 24681;
const rnd = () => (s = (s * 1103515245 + 12345) & 0x7fffffff) / 0x7fffffff;
const g: boolean[][] = Array.from({ length: N }, () =>
  Array.from({ length: N }, () => rnd() > 0.5),
);
const stamp = (r0: number, c0: number) => {
  for (let r = 0; r < 7; r++)
    for (let c = 0; c < 7; c++) {
      const edge = r === 0 || r === 6 || c === 0 || c === 6;
      const core = r >= 2 && r <= 4 && c >= 2 && c <= 4;
      g[r0 + r][c0 + c] = edge || core;
    }
};
const clear = (r0: number, c0: number, h: number, w: number) => {
  for (let r = 0; r < h; r++) for (let c = 0; c < w; c++) g[r0 + r][c0 + c] = false;
};
clear(0, 7, 8, 1);
clear(7, 0, 1, 8);
clear(0, N - 8, 8, 1);
clear(7, N - 8, 1, 8);
clear(N - 8, 0, 8, 1);
clear(N - 8, 7, 1, 8);
stamp(0, 0);
stamp(0, N - 7);
stamp(N - 7, 0);

const cells = g.flat();
---

<div
  class="mck-qr-grid"
  style={`width:${size}px;height:${size}px;padding:${size * 0.05}px;`}
  aria-hidden="true"
>
  {cells.map((on) => <i style={on ? `background:${color}` : ''}></i>)}
</div>
