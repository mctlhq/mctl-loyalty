---
// "Rewards catalog" screen — rewards list with blue price pills + empty history.
import MckChrome from '../MckChrome.astro';

const items = [
  ['Specialty coffee', 'Cappuccino or filter', '120'],
  ['Double gelato scoop', 'Any two flavours', '200'],
  ['Dessert of the day', "Barista's choice", '300'],
];
---

<div class="mck-app">
  <MckChrome />
  <div class="mck-rewards">
    <div class="mck-card-title">Rewards</div>
    {
      items.map((it, i) => (
        <div class:list={['mck-reward-row', { 'mck-row-bt': i }]}>
          <div class="mck-reward-text">
            <div class="mck-reward-title">{it[0]}</div>
            <div class="mck-reward-desc">{it[1]}</div>
          </div>
          <div class="mck-pill">{it[2]}</div>
        </div>
      ))
    }
  </div>
  <div class="mck-history">
    <div class="mck-card-title">History</div>
    <div class="mck-empty">No operations yet</div>
  </div>
</div>
