---
// "Your rotating QR" screen — points card (zero balance) + QR card.
import MckChrome from '../MckChrome.astro';
import FakeQr from '../FakeQr.astro';
---

<div class="mck-app">
  <MckChrome />
  <div class="mck-points">
    <div class="mck-balance"><span class="mck-balance-n">0</span><span class="mck-balance-u">points</span></div>
    <div class="mck-user">@dmitriimashkov</div>
    <div class="mck-idline">
      <span class="mck-id-k">ID:</span>
      <span class="mck-id-v">924671154</span>
      <span class="mck-copy">Copy</span>
    </div>
  </div>
  <div class="mck-qr">
    <div class="mck-qr-box"><FakeQr size={188} /></div>
    <div class="mck-qr-cap">Show this QR to staff. It refreshes automatically.</div>
  </div>
</div>
