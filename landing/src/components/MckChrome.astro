---
// Telegram-style status bar + Mini App header, shared by every product
// mockup screen. `time` lets the app and admin shots show different clocks
// (09:36 vs 10:00) like the design prototype.
interface Props {
  time?: string;
}
const { time = '09:36' } = Astro.props;
---

<div class="mck-status">
  <span>{time}</span>
  <span class="mck-status-right">
    <span class="mck-dots">●●●</span>
    <span class="mck-lte">LTE</span>
    <span class="mck-batt"><i></i></span>
  </span>
</div>
<div class="mck-head">
  <span class="mck-head-x">×</span>
  <span class="mck-head-title">MCTL Rewards</span>
  <span class="mck-head-i">⌄</span>
  <span class="mck-head-i">⋮</span>
</div>
