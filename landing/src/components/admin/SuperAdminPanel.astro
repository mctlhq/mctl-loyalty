---
// Super-admin Mini App panel — program setup, redesigned to the live tabbed
// shell. Super-admins get 5 tabs; this shows the Program tab: program-control
// action cards + the cross-merchant "All accrual rules" list (global + per-merchant).
import MckChrome from '../MckChrome.astro';
import MckTabBar from './MckTabBar.astro';

const ACTIONS = [
  { title: 'New merchant', sub: 'Shop, café or venue', icon: '<path d="M3 9h18M3 9l1.5-5h15L21 9M4 9v11h16V9M9 13h6"/>' },
  { title: 'Add staff (any merchant)', sub: 'Scanner or admin by ID', icon: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { title: 'Global accrual rule', sub: 'Applies across merchants', icon: '<path d="M13 2 3 14h9l-1 8 10-12h-9z"/>' },
  { title: 'Global reward', sub: 'Cost + optional stock', icon: '<rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13M5 12v9h14v-9M12 8a3 3 0 1 0-3-3 3 3 0 0 0 3 3 3 3 0 1 0 3-3 3 3 0 0 0-3 3"/>' },
];

const RULES = [
  { name: 'Purchase', sub: 'Global · +20' },
  { name: 'Visit', sub: 'Global · +50 · max 2/day' },
  { name: 'Latte of the day', sub: 'Capulus Coffee · +30 · max 1/day' },
];
---

<div class="mck-app mck-app-tabs">
  <MckChrome time="10:00" />
  <div class="mck-body">
    <div class="mck-seclabel">Program control</div>
    {
      ACTIONS.map((a) => (
        <div class="mck-actionrow">
          <span class="mck-act-ico">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={a.icon} />
          </span>
          <div class="mck-act-txt">
            <b>{a.title}</b><span>{a.sub}</span>
          </div>
          <span class="mck-act-plus">+</span>
        </div>
      ))
    }
    <div class="mck-seclabel mck-seclabel-mt">All accrual rules</div>
    {
      RULES.map((r) => (
        <div class="mck-rulerow">
          <div class="mck-rule-txt">
            <b>{r.name}</b><span>{r.sub}</span>
          </div>
          <span class="mck-ghost">Deactivate</span>
        </div>
      ))
    }
  </div>
  <MckTabBar tabs={['scan', 'requests', 'staff', 'rules', 'program']} active="program" />
</div>
