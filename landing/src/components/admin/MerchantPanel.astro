---
// Merchant-staff Mini App panel — the counter, redesigned to the live tabbed
// shell (Scan tab of the role-based admin). Merchant-admins get 4 tabs
// (scan/requests/staff/rules); this shows the Scan tab with the in-DOM main bar.
import MckChrome from '../MckChrome.astro';
import MckTabBar from './MckTabBar.astro';
---

<div class="mck-app mck-app-tabs">
  <MckChrome time="10:00" />
  <div class="mck-body">
    <div class="mck-seclabel">Counter</div>
    <div class="mck-selrow">
      <div class="mck-selrow-txt">
        <b>Capulus Coffee</b><span>You're an admin here</span>
      </div>
      <span class="mck-tag">Admin</span>
    </div>
    <div class="mck-acard mck-scanhero">
      <span class="mck-scan-ico">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="7" height="7" rx="1"></rect>
          <rect x="14" y="3" width="7" height="7" rx="1"></rect>
          <rect x="3" y="14" width="7" height="7" rx="1"></rect>
          <path d="M14 14h3v3M21 21v.01M21 17v.01M17 21v.01"></path>
        </svg>
      </span>
      <div class="mck-scan-title">Ready to scan</div>
      <p class="mck-scan-sub">
        Tap <b>Scan to award</b>, point at the member's rotating QR, then pick an
        accrual rule. Points credit instantly.
      </p>
    </div>
  </div>
  <div class="mck-mainbar">
    <span class="mck-scanlink">Scan redemption</span>
    <div class="mck-btn mck-btn-full">Scan to award</div>
  </div>
  <MckTabBar tabs={['scan', 'requests', 'staff', 'rules']} active="scan" />
</div>
