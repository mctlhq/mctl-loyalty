---
import Base from '../layouts/Base.astro';

const title = 'Terms of Service — MCTL Rewards';
const description =
  'The terms that govern your use of the MCTL Rewards Telegram Mini App loyalty program.';
---

<Base title={title} description={description} path="/terms">
  <main class="container doc">
    <h1>Terms of Service</h1>
    <span class="draft">Draft — placeholder copy, not yet legal advice</span>

    <p>
      These terms govern your use of the MCTL Rewards Telegram Mini App ("the
      Service"). This is a draft and will be replaced with finalized terms
      before general availability. By using the Service you agree to the
      following.
    </p>

    <h2>The program</h2>
    <p>
      MCTL Rewards is a community loyalty program. Points have no cash value,
      are not transferable for money, and may be earned or redeemed only within
      participating merchants according to their own accrual rules and rewards
      catalogs.
    </p>

    <h2>Your account</h2>
    <p>
      Your account is tied to your Telegram identity. You are responsible for
      activity that occurs through your account. Do not attempt to manipulate,
      duplicate, or reuse QR codes, or otherwise abuse the points system.
    </p>

    <h2>Points and rewards</h2>
    <p>
      Points balances reflect transactions recorded by participating merchants.
      Rewards availability, accrual rates, and reward costs are set by
      merchants and community administrators and may change at any time.
    </p>

    <h2>Availability</h2>
    <p>
      The Service is provided "as is" without warranties. We may modify or
      discontinue features at any time. Community administrators operate
      individual instances of the Service and set their own rules.
    </p>

    <h2>Contact</h2>
    <p>
      Questions about these terms can be directed to the community
      administrators that operate this instance of the Service.
    </p>

    <a class="back" href="/">← Back to home</a>
  </main>
</Base>
